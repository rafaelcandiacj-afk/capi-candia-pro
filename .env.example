# ─── Capi Când-IA Pro — Variáveis de Ambiente ───
# Copie este arquivo para .env e preencha os valores

# Servidor
PORT=3001
JWT_SECRET=seu-secret-aqui
ADMIN_PASSWORD=sua-senha-admin

# Banco de dados
DB_PATH=./backend/capi.db

# ─── APIs de IA ───
OPENAI_API_KEY=sk-...
CAPI_FINETUNED_MODEL=ft:gpt-4.1-mini-2025-04-14:personal:capi-juridico:DTj8Jwm2
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Email (Resend) ───
RESEND_API_KEY=re_...

# ─── Webhooks ───
PAGARME_WEBHOOK_SECRET=seu-secret-pagarme
PAGARME_MONTHLY_URL=https://clkdmg.site/subscribe/mensal-capi-candia-pro
PAGARME_ANNUAL_URL=https://clkdmg.site/subscribe/anual-capi-candia-pro

# ─── Guru: Offer IDs para detecção de tier PRO ───
# IMPORTANTE: Tier é detectado por OFFER_ID, não por product_id!
# Preencha com os IDs das ofertas PRO criadas na Guru.
# Sem estas vars, o fallback por valor da transação é usado.
GURU_OFFER_ID_MONTHLY_97=    # ID da oferta R$97/mês na Guru
GURU_OFFER_ID_ANNUAL_804=    # ID da oferta R$804/ano na Guru

# ─── Guru: Product IDs (deprecated — não usados para detectar tier) ───
# Mantidos para compatibilidade, mas a detecção de tier usa OFFER_ID acima.
# GURU_PRODUCT_ID_MONTHLY_97=
# GURU_PRODUCT_ID_ANNUAL_97=
